#!/usr/bin/env python3
# slughorn-sdf -- generate SDF tiles from a slughorn atlas.
#
# Uses atlas.render_sdf() (msdfgen, analytic) when available; falls back to the
# scipy coverage-grid + distance-transform path when msdfgen is not compiled in.
#
# Usage:
# python3 slughorn-sdf # demo mode: circle + triangle
# python3 slughorn-sdf atlas.slug # load a .slug / .slugb file
#
# Output:
# slughorn_sdf_atlas.png -- packed SDF atlas (RGB uint8)
# slughorn_sdf_atlas.json -- sidecar: key -> { atlasX, atlasY, tileW, tileH }

import sys
import json
from pathlib import Path
import numpy as np
from PIL import Image

sys.path.insert(0, str(Path(__file__).resolve().parents[1] / "BUILD"))

import slughorn
import slughorn.canvas

TILE = 128 # target tile size on longest axis (texels)
SDF_RANGE = 0.1 # em-space spread passed to msdfgen
ATLAS_WIDTH = 1024 # output atlas width (texels)
OUT_PNG = "slughorn_sdf_atlas.png"
OUT_JSON = "slughorn_sdf_atlas.json"

# --- msdfgen path (preferred) ---

def make_sdf_tile_msdfgen(atlas, key):
	arr = atlas.render_sdf(key, tile_size=TILE, range=SDF_RANGE) # float32 (H, W)
	if arr.max() < 0.5:
		return None # no interior -- empty/whitespace shape
	return Image.fromarray((np.clip(arr, 0.0, 1.0) * 255).astype("uint8"))

# --- scipy fallback path (no msdfgen) ---

def make_sdf_tile_scipy(atlas, key):
	from scipy.ndimage import distance_transform_edt

	SUPERSAMPLE = 8
	MAX_DIST_FRAC = 0.1
	RENDER_MARGIN = MAX_DIST_FRAC / (1.0 - 2.0 * MAX_DIST_FRAC)

	decoded = atlas.decode(key)
	coverage = decoded.render_grid(TILE * SUPERSAMPLE, RENDER_MARGIN, True)

	if float(coverage.max()) < 0.01:
		return None

	mask = coverage > 0.5
	inside = distance_transform_edt(mask)
	outside = distance_transform_edt(~mask)
	max_dist = MAX_DIST_FRAC * TILE * SUPERSAMPLE
	sdf_norm = np.clip(0.5 + (inside - outside) / (2.0 * max_dist), 0.0, 1.0)

	h, w = sdf_norm.shape
	scale = TILE / max(w, h)
	tw, th = max(1, round(w * scale)), max(1, round(h * scale))
	img = Image.fromarray((sdf_norm * 255).astype("uint8"))
	return img.resize((tw, th), Image.LANCZOS)

# --- dispatch ---

USE_MSDFGEN = hasattr(slughorn.Atlas, "render_sdf")

def make_sdf_tile(atlas, key):
	if USE_MSDFGEN:
		return make_sdf_tile_msdfgen(atlas, key)
	return make_sdf_tile_scipy(atlas, key)


def pack_tiles(tiles):
	cx, cy, row_h = 0, 0, 0
	recs = {}

	for key, img in tiles.items():
		w, h = img.size
		if cx + w > ATLAS_WIDTH:
			cx, cy, row_h = 0, cy + row_h, 0
		recs[key] = {"atlasX": cx, "atlasY": cy, "tileW": w, "tileH": h}
		cx += w
		row_h = max(row_h, h)

	atlas_h = cy + row_h
	out = Image.new("RGB", (ATLAS_WIDTH, max(atlas_h, 1)), 0)

	for key, img in tiles.items():
		r = recs[key]
		out.paste(img.convert("RGB"), (r["atlasX"], r["atlasY"]))

	return out, recs


def build_demo_atlas():
	atlas = slughorn.Atlas()
	canvas = slughorn.canvas.Canvas(atlas)

	canvas.circle(0.5, 0.5, 0.45)
	canvas.fill(slughorn.Color(1, 1, 1, 1), 1.0, "circle")
	canvas.finalize("circle_comp")

	canvas.begin_path()
	canvas.move_to(0.5, 0.05)
	canvas.line_to(0.95, 0.95)
	canvas.line_to(0.05, 0.95)
	canvas.close_path()
	canvas.fill(slughorn.Color(1, 1, 1, 1), 1.0, "triangle")
	canvas.finalize("triangle_comp")

	atlas.build()
	return atlas


def main():
	if len(sys.argv) > 1:
		atlas = slughorn.read(sys.argv[1])
		print(f"Loaded: {sys.argv[1]}")
	else:
		atlas = build_demo_atlas()
		print("Demo atlas: circle + triangle")

	shapes = atlas.get_shapes()
	path = "msdfgen (analytic)" if USE_MSDFGEN else "scipy (coverage DT fallback)"
	print(f"{len(shapes)} shape(s) -- generating SDF tiles [{path}]...\n")

	tiles = {}
	skipped = []

	for key in shapes:
		tile = make_sdf_tile(atlas, key)
		if tile is None:
			skipped.append(str(key))
		else:
			tiles[str(key)] = tile
			print(f" {str(key):<24} {tile.size[0]}x{tile.size[1]}")

	if skipped:
		print(f"\n skipped (no geometry): {', '.join(skipped)}")

	if not tiles:
		print("No renderable shapes found.")
		sys.exit(1)

	atlas_img, sidecar = pack_tiles(tiles)
	atlas_img.save(OUT_PNG)

	with open(OUT_JSON, "w") as f:
		json.dump(sidecar, f, indent=2)

	aw, ah = atlas_img.size
	print(f"\n-> {OUT_PNG} ({aw}x{ah})")
	print(f"-> {OUT_JSON}")


if __name__ == "__main__":
	main()
